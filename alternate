<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Built to Last — The Operating System for High-Performing Men</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Barlow+Condensed:wght@300;400;600;700;900&family=Barlow:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --black: #090909;
    --near-black: #0f0f0f;
    --dark: #161616;
    --charcoal: #1e1e1e;
    --gold: #c9a84c;
    --gold-light: #e2c47a;
    --gold-dim: #7a6028;
    --cream: #f0ebe0;
    --cream-dim: #a89f8c;
    --white: #fafaf8;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--black);
    color: var(--cream);
    font-family: 'Barlow', sans-serif;
    font-weight: 300;
    overflow-x: hidden;
    cursor: crosshair;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='1'/%3E%3C/svg%3E");
    opacity: 0.03;
    pointer-events: none;
    z-index: 9999;
  }

  /* NAV */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 28px 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid rgba(201,168,76,0.12);
    background: rgba(9,9,9,0.85);
    backdrop-filter: blur(20px);
    animation: fadeDown 1s ease forwards;
    transition: border-color 0.3s;
  }

  .nav-logo {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .nav-links { display: flex; gap: 48px; list-style: none; }
  .nav-links a {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px; font-weight: 600;
    letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--cream-dim); text-decoration: none;
    transition: color 0.3s;
  }
  .nav-links a:hover { color: var(--gold); }

  .nav-cta {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--black); background: var(--gold);
    padding: 10px 24px; text-decoration: none;
    transition: background 0.3s, transform 0.2s;
  }
  .nav-cta:hover { background: var(--gold-light); transform: translateY(-1px); }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    position: relative;
    overflow: hidden;
  }

  .hero-left {
    padding: 180px 60px 100px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    position: relative;
    z-index: 2;
  }

  .hero-eyebrow {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px; font-weight: 600;
    letter-spacing: 0.5em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 36px;
    opacity: 0;
    animation: fadeUp 1s 0.5s ease forwards;
  }

  .hero-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(56px, 6vw, 96px);
    font-weight: 900; line-height: 0.95;
    color: var(--white); margin-bottom: 40px;
    opacity: 0;
    animation: fadeUp 1s 0.7s ease forwards;
  }
  .hero-title em { font-style: italic; color: var(--gold); }

  .hero-sub {
    font-size: 16px; font-weight: 300; line-height: 1.7;
    color: var(--cream-dim); max-width: 420px; margin-bottom: 56px;
    opacity: 0;
    animation: fadeUp 1s 0.9s ease forwards;
  }

  .hero-actions {
    display: flex; gap: 20px; align-items: center;
    opacity: 0;
    animation: fadeUp 1s 1.1s ease forwards;
  }

  .btn-primary {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 12px; font-weight: 700;
    letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--black); background: var(--gold);
    padding: 16px 36px; text-decoration: none;
    transition: all 0.3s; display: inline-block; cursor: pointer;
    border: none;
  }
  .btn-primary:hover {
    background: var(--gold-light); transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(201,168,76,0.25);
  }

  .btn-secondary {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 12px; font-weight: 600;
    letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--cream-dim); text-decoration: none;
    border-bottom: 1px solid rgba(201,168,76,0.4);
    padding-bottom: 2px; transition: color 0.3s, border-color 0.3s;
    cursor: pointer; background: none; border-top: none; border-left: none; border-right: none;
  }
  .btn-secondary:hover { color: var(--gold); border-bottom-color: var(--gold); }

  .hero-right { position: relative; overflow: hidden; }

  .hero-bg {
    position: absolute; inset: 0;
    background:
      linear-gradient(135deg, transparent 40%, rgba(201,168,76,0.06) 100%),
      repeating-linear-gradient(0deg, transparent, transparent 80px, rgba(201,168,76,0.03) 80px, rgba(201,168,76,0.03) 81px),
      repeating-linear-gradient(90deg, transparent, transparent 80px, rgba(201,168,76,0.03) 80px, rgba(201,168,76,0.03) 81px);
  }

  .hero-number {
    position: absolute; bottom: -20px; right: -30px;
    font-family: 'Playfair Display', serif;
    font-size: 280px; font-weight: 900;
    color: rgba(201,168,76,0.04); line-height: 1;
    user-select: none;
    opacity: 0; animation: fadeIn 2s 0.3s ease forwards;
  }

  .hero-pillars {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 2px; width: 380px;
    opacity: 0; animation: fadeIn 1.5s 1.3s ease forwards;
  }

  .pillar-card {
    background: rgba(22,22,22,0.9);
    border: 1px solid rgba(201,168,76,0.15);
    padding: 32px 28px;
    transition: border-color 0.3s, background 0.3s;
    cursor: default;
  }
  .pillar-card:hover { border-color: rgba(201,168,76,0.5); background: rgba(30,30,30,0.95); }

  .pillar-num {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px; font-weight: 600;
    letter-spacing: 0.3em; color: var(--gold-dim); margin-bottom: 12px;
  }

  .pillar-name {
    font-family: 'Playfair Display', serif;
    font-size: 22px; font-weight: 700;
    color: var(--white); margin-bottom: 8px;
  }

  .pillar-desc { font-size: 12px; font-weight: 300; color: var(--cream-dim); line-height: 1.6; }

  /* MARQUEE */
  .marquee-section {
    border-top: 1px solid rgba(201,168,76,0.15);
    border-bottom: 1px solid rgba(201,168,76,0.15);
    padding: 18px 0; overflow: hidden;
    background: var(--near-black);
  }

  .marquee-track {
    display: flex; gap: 0;
    animation: marquee 25s linear infinite;
    white-space: nowrap;
  }

  .marquee-item {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 12px; font-weight: 600;
    letter-spacing: 0.4em; text-transform: uppercase;
    color: var(--gold-dim); padding: 0 48px;
    display: inline-flex; align-items: center; gap: 48px;
  }

  .marquee-dot { width: 4px; height: 4px; background: var(--gold); border-radius: 50%; display: inline-block; }

  /* MANIFESTO */
  .manifesto {
    padding: 160px 60px;
    max-width: 900px; margin: 0 auto;
    text-align: center; position: relative;
  }

  .manifesto::before {
    content: '"';
    position: absolute; top: 80px; left: 50%; transform: translateX(-50%);
    font-family: 'Playfair Display', serif;
    font-size: 200px; color: rgba(201,168,76,0.06); line-height: 1;
    user-select: none;
  }

  .manifesto-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px; font-weight: 600;
    letter-spacing: 0.5em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 32px;
  }

  .gold-line { width: 60px; height: 2px; background: var(--gold); margin: 0 auto 48px; }

  .manifesto-text {
    font-family: 'Playfair Display', serif;
    font-size: clamp(26px, 3.5vw, 42px);
    font-weight: 400; line-height: 1.5;
    color: var(--white); position: relative; z-index: 1;
  }
  .manifesto-text strong { font-weight: 700; color: var(--gold); }

  /* STATS */
  .stats-bar {
    display: grid; grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid rgba(201,168,76,0.12);
    border-bottom: 1px solid rgba(201,168,76,0.12);
  }

  .stat {
    padding: 64px 40px;
    border-right: 1px solid rgba(201,168,76,0.12);
    text-align: center;
    transition: background 0.4s;
  }
  .stat:last-child { border-right: none; }
  .stat:hover { background: rgba(201,168,76,0.04); }

  .stat-num {
    font-family: 'Playfair Display', serif;
    font-size: 56px; font-weight: 900;
    color: var(--gold); line-height: 1; margin-bottom: 12px;
  }

  .stat-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px; font-weight: 600;
    letter-spacing: 0.35em; text-transform: uppercase;
    color: var(--cream-dim);
  }

  /* OS SECTION */
  .os-section {
    padding: 160px 60px;
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 120px; align-items: center;
    max-width: 1400px; margin: 0 auto;
  }

  .section-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px; font-weight: 600;
    letter-spacing: 0.5em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 28px;
    display: block;
  }

  .os-left h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(36px, 4vw, 60px); font-weight: 900;
    line-height: 1.05; color: var(--white); margin-bottom: 28px;
  }
  .os-left h2 em { font-style: italic; color: var(--gold); }

  .os-left p {
    font-size: 16px; line-height: 1.75;
    color: var(--cream-dim); margin-bottom: 48px;
  }

  .os-principles { display: flex; flex-direction: column; }

  .principle {
    display: flex; align-items: flex-start; gap: 24px;
    padding: 28px 0;
    border-bottom: 1px solid rgba(201,168,76,0.1);
    cursor: default;
    transition: padding-left 0.3s;
  }
  .principle:hover { padding-left: 8px; }
  .principle:first-child { border-top: 1px solid rgba(201,168,76,0.1); }

  .principle-num {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.2em; color: var(--gold-dim);
    min-width: 32px; padding-top: 2px;
  }

  .principle-content h4 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 16px; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--white); margin-bottom: 6px;
  }

  .principle-content p { font-size: 14px; color: var(--cream-dim); line-height: 1.6; margin: 0; }

  /* PODCAST */
  .podcast-section {
    background: var(--near-black);
    padding: 160px 60px;
    position: relative; overflow: hidden;
  }

  .podcast-section::before {
    content: 'PODCAST';
    position: absolute; top: 60px; right: -20px;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 160px; font-weight: 900;
    color: rgba(201,168,76,0.04); letter-spacing: 0.1em;
    user-select: none; white-space: nowrap;
  }

  .podcast-inner { max-width: 1300px; margin: 0 auto; }

  .section-header {
    display: flex; justify-content: space-between;
    align-items: flex-end; margin-bottom: 80px;
  }

  .section-header h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(32px, 3.5vw, 52px); font-weight: 900;
    color: var(--white); line-height: 1.1;
  }

  .featured-episode {
    display: grid; grid-template-columns: 1fr 1.2fr;
    gap: 80px; align-items: center;
    padding: 60px;
    border: 1px solid rgba(201,168,76,0.15);
    background: rgba(22,22,22,0.7);
    position: relative; z-index: 1;
  }

  .ep-artwork {
    aspect-ratio: 1; background: var(--charcoal);
    border: 1px solid rgba(201,168,76,0.15);
    position: relative; overflow: hidden;
    display: flex; align-items: center; justify-content: center;
  }

  .ep-artwork-inner {
    width: 80%; height: 80%;
    border: 1px solid rgba(201,168,76,0.2);
    display: flex; align-items: center; justify-content: center;
    flex-direction: column; gap: 16px;
  }

  .ep-artwork-logo {
    font-family: 'Playfair Display', serif;
    font-size: 32px; font-weight: 900; color: var(--gold);
  }

  .ep-artwork-sub {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 10px; letter-spacing: 0.4em;
    color: var(--cream-dim); text-transform: uppercase;
  }

  .play-btn {
    position: absolute; bottom: 20px; right: 20px;
    width: 52px; height: 52px;
    background: var(--gold); border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.3s, transform 0.2s;
  }
  .play-btn:hover { background: var(--gold-light); transform: scale(1.05); }

  .play-icon {
    width: 0; height: 0;
    border-top: 9px solid transparent;
    border-bottom: 9px solid transparent;
    border-left: 16px solid var(--black);
    margin-left: 3px;
  }

  .ep-num {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px; font-weight: 600;
    letter-spacing: 0.4em; color: var(--gold);
    text-transform: uppercase; margin-bottom: 20px; display: block;
  }

  .ep-meta h3 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(24px, 2.5vw, 36px); font-weight: 700;
    color: var(--white); line-height: 1.2; margin-bottom: 20px;
  }

  .ep-meta p { font-size: 15px; line-height: 1.7; color: var(--cream-dim); margin-bottom: 36px; }

  .ep-tags { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 36px; }

  .ep-tag {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 10px; font-weight: 700;
    letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--gold-dim); border: 1px solid rgba(201,168,76,0.25);
    padding: 6px 14px;
  }

  /* NEWSLETTER */
  .newsletter-section {
    padding: 160px 60px;
    max-width: 800px; margin: 0 auto;
    text-align: center; position: relative;
  }

  .newsletter-section::after {
    content: '';
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(201,168,76,0.05) 0%, transparent 70%);
    pointer-events: none;
  }

  .newsletter-section h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(36px, 4vw, 60px); font-weight: 900;
    color: var(--white); line-height: 1.1; margin-bottom: 24px;
  }

  .newsletter-section > p {
    font-size: 16px; color: var(--cream-dim);
    line-height: 1.7; margin-bottom: 56px;
  }

  .email-form {
    display: flex; gap: 0;
    max-width: 540px; margin: 0 auto;
    position: relative; z-index: 1;
  }

  .email-input {
    flex: 1; padding: 18px 24px;
    background: var(--dark);
    border: 1px solid rgba(201,168,76,0.25);
    border-right: none;
    color: var(--white);
    font-family: 'Barlow', sans-serif; font-size: 14px;
    outline: none; transition: border-color 0.3s;
  }
  .email-input:focus { border-color: var(--gold); }
  .email-input::placeholder { color: var(--cream-dim); opacity: 0.5; }

  .email-submit {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 12px; font-weight: 700;
    letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--black); background: var(--gold);
    border: none; padding: 18px 36px;
    cursor: pointer; transition: background 0.3s;
  }
  .email-submit:hover { background: var(--gold-light); }

  .newsletter-note {
    font-size: 12px; color: var(--cream-dim); opacity: 0.5; margin-top: 20px;
  }

  /* COMMUNITY */
  .community-section {
    background: var(--near-black);
    padding: 160px 60px;
    position: relative; overflow: hidden;
  }

  .community-inner {
    max-width: 1300px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 100px; align-items: center;
  }

  .community-left h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(36px, 3.5vw, 52px); font-weight: 900;
    color: var(--white); line-height: 1.1; margin-bottom: 28px;
  }
  .community-left h2 em { font-style: italic; color: var(--gold); }

  .community-left > p {
    font-size: 16px; color: var(--cream-dim);
    line-height: 1.75; margin-bottom: 48px;
  }

  .community-features { display: flex; flex-direction: column; gap: 24px; }

  .c-feature { display: flex; gap: 20px; align-items: flex-start; }

  .c-icon {
    width: 40px; height: 40px;
    border: 1px solid rgba(201,168,76,0.3);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; font-size: 14px; color: var(--gold);
  }

  .c-feature-text h4 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 14px; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--white); margin-bottom: 4px;
  }

  .c-feature-text p { font-size: 13px; color: var(--cream-dim); line-height: 1.6; margin: 0; }

  .society-card {
    border: 1px solid rgba(201,168,76,0.2);
    background: rgba(22,22,22,0.8);
    padding: 60px; text-align: center; position: relative;
  }

  .society-card::before {
    content: '';
    position: absolute; top: 12px; left: 12px; right: -12px; bottom: -12px;
    border: 1px solid rgba(201,168,76,0.08); z-index: -1;
  }

  .society-badge {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 10px; font-weight: 700;
    letter-spacing: 0.4em; text-transform: uppercase;
    color: var(--gold); border: 1px solid rgba(201,168,76,0.4);
    padding: 8px 20px; display: inline-block; margin-bottom: 40px;
  }

  .society-title {
    font-family: 'Playfair Display', serif;
    font-size: 36px; font-weight: 900; color: var(--white); margin-bottom: 12px;
  }

  .society-subtitle {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 12px; letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--gold-dim); margin-bottom: 40px;
  }

  .society-divider {
    height: 1px; background: rgba(201,168,76,0.15);
    margin: 0 -60px 40px;
  }

  .society-members {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px; font-weight: 600;
    letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--cream-dim); margin-bottom: 32px;
  }
  .society-members span { color: var(--gold); }

  /* FOOTER */
  footer {
    border-top: 1px solid rgba(201,168,76,0.12);
    padding: 80px 60px 60px;
    display: grid; grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 60px; background: var(--near-black);
  }

  .footer-brand .logo {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 13px; font-weight: 700;
    letter-spacing: 0.4em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 20px; display: block;
  }

  .footer-brand > p {
    font-size: 14px; color: var(--cream-dim);
    line-height: 1.7; max-width: 280px; margin-bottom: 28px;
  }

  .footer-col h5 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.4em; text-transform: uppercase;
    color: var(--cream-dim); margin-bottom: 24px;
  }

  .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 12px; }

  .footer-col a {
    font-size: 14px; color: rgba(160,150,130,0.6);
    text-decoration: none; transition: color 0.3s;
  }
  .footer-col a:hover { color: var(--gold); }

  .footer-bottom {
    border-top: 1px solid rgba(201,168,76,0.08);
    padding: 24px 60px;
    display: flex; justify-content: space-between; align-items: center;
    background: var(--near-black);
  }

  .footer-bottom p {
    font-size: 12px; color: rgba(160,150,130,0.4);
    font-family: 'Barlow Condensed', sans-serif; letter-spacing: 0.1em;
  }

  /* ANIMATIONS */
  @keyframes fadeDown { from { opacity:0; transform:translateY(-20px); } to { opacity:1; transform:translateY(0); } }
  @keyframes fadeUp { from { opacity:0; transform:translateY(30px); } to { opacity:1; transform:translateY(0); } }
  @keyframes fadeIn { from { opacity:0; } to { opacity:1; } }
  @keyframes marquee { 0% { transform:translateX(0); } 100% { transform:translateX(-50%); } }

  .reveal { opacity:0; transform:translateY(40px); transition:opacity 0.8s ease, transform 0.8s ease; }
  .reveal.visible { opacity:1; transform:translateY(0); }

